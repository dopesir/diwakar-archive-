# Security headers for Cloudflare Pages. The site is fully static; the main
# pages need only same-origin resources. The /admin/ route additionally loads
# Sveltia CMS from unpkg and talks to GitHub.
#
# Scripts are bundled to external first-party files (astro.config vite
# assetsInlineLimit: 0), so script-src needs NO 'unsafe-inline'. style-src keeps
# 'unsafe-inline' because Astro inlines small first-party stylesheets (no script
# execution risk there).
#
# Cloudflare JOINS duplicate headers from multiple matching rules with a comma,
# and comma-joined CSPs enforce BOTH — so /admin/ must DETACH the global CSP
# first with "!" before declaring its own, or the global policy would block
# unpkg/GitHub there.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests

/admin/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' https://unpkg.com; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: blob: https://*.githubusercontent.com https://*.gravatar.com; font-src 'self' data: https://unpkg.com; connect-src 'self' https://unpkg.com https://api.github.com https://www.githubstatus.com https://*.githubusercontent.com; frame-src 'self'; object-src 'none'; base-uri 'self'
