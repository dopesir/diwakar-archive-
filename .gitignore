# build output
dist/
.astro/

# dependencies
node_modules/

# logs / env / os
npm-debug.log*
.env
.env.production
.DS_Store
Thumbs.db

# NOTES:
# - source-assets/ and reference/ are intentionally NOT ignored — they hold the
#   originals so future contributors keep the source material.
# - src/assets/ IS committed (processed images + CMS uploads). The host build
#   command is only `npm run build`; it does not run prepare-images, so the
#   downscaled images must be in the repo for deploys to succeed.
