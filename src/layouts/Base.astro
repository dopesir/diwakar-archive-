---
// Manrope variable (subsets unicode-range-gated)
// for English content (§9.5). font-display:swap is the @fontsource default.
import '@fontsource-variable/manrope';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

import type { ImageMetadata } from 'astro';
import defaultOg from '../assets/hero/desktop/DSC_1209.jpg';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';
import Reveal from '../components/Reveal.astro';
import ConnectCta from '../components/ConnectCta.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import SEO from '../components/SEO.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import { getSiteSettings, themeStyle } from '../lib/site';

interface Props {
  title: string;
  description: string;
  ogImage?: ImageMetadata;
  ogType?: string;
  /** Home page only: nav starts transparent over the hero, then turns solid on scroll. */
  home?: boolean;
  hideNav?: boolean;
  /** Optional per-page/entry SEO overrides (Tier 1C). Each falls back when blank. */
  seoTitle?: string;
  seoDescription?: string;
  shareImage?: ImageMetadata;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage,
  ogType = 'website',
  home = false,
  hideNav = false,
  seoTitle,
  seoDescription,
  shareImage,
  noindex = false,
} = Astro.props;

// Global Site Settings (CMS): SEO defaults, share image, analytics, announcement.
const site = await getSiteSettings();

// SEO fallback chain: per-entry override → page prop → Site Settings default → built-in.
const finalTitle = seoTitle?.trim() ? seoTitle : title;
const finalDescription = seoDescription?.trim()
  ? seoDescription
  : description?.trim()
    ? description
    : site.seo.defaultDescription;
const finalImage = shareImage ?? ogImage ?? site.seo.shareImage ?? defaultOg;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// Announcement bar offsets the (locked) nav via a CSS class — no nav markup change.
const showAnnounce = site.announcement.enabled && site.announcement.text.trim() !== '';

// Constrained theme tokens (3B): inline CSS custom properties on <html>.
// Empty string when everything is default, so default output is unchanged.
const themeVars = themeStyle(site.appearance);

// Locale-stripped path (3C). Lets the LOCKED Nav's active states and the
// ConnectCta skip keep working under /hi/ without editing Nav.astro. For English
// pages this equals the pathname, so English output stays byte-identical.
const localePath = Astro.url.pathname.replace(/^\/hi(?=\/|$)/, '') || '/';
---

<!doctype html>
<html
  lang={Astro.currentLocale ?? 'en'}
  class={showAnnounce ? 'has-announce' : undefined}
  style={themeVars || undefined}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <SEO
      title={finalTitle}
      description={finalDescription}
      canonical={canonical}
      ogType={ogType}
      siteName={site.seo.ogSiteName}
      image={finalImage}
      noindex={noindex}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0806" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />

    {
      /* Privacy-friendly analytics — external (never inline, CSP-safe), rendered
         only when the client sets a script URL. Enabling it also requires
         whitelisting the origin in public/_headers. */
    }
    {
      site.analytics.scriptUrl && (
        <script
          defer
          src={site.analytics.scriptUrl}
          data-site={site.analytics.siteId || undefined}
        />
      )
    }

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": `${Astro.site}#website`,
          "url": Astro.site,
          "name": site.seo.ogSiteName,
          "description": site.seo.defaultDescription,
          "publisher": {
            "@id": `${Astro.site}#person`
          }
        },
        {
          "@type": "Person",
          "@id": `${Astro.site}#person`,
          "name": "Purushottam Diwakar",
          "url": Astro.site,
          "jobTitle": "Photojournalist",
          "description": "Purushottam Diwakar is a renowned photojournalist and war photographer based in India, documenting rural movements, politics, and historical events."
        }
      ]
    })} />

    <slot name="head" />

    <script>
      // ── ANTI-THEFT SECURITY PROFILE ────────────────────────────
      // Protect assets by disabling context menus and common scraping shortcuts.
      
      // 1. Disable Right-Click (Context Menu)
      document.addEventListener('contextmenu', (e) => e.preventDefault());
      
      // 2. Disable Keyboard Shortcuts (Save, Print, DevTools)
      document.addEventListener('keydown', (e) => {
        const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
        const cmdOrCtrl = isMac ? e.metaKey : e.ctrlKey;
        
        // Block Cmd/Ctrl + S (Save Page)
        if (cmdOrCtrl && e.key.toLowerCase() === 's') {
          e.preventDefault();
        }
        // Block Cmd/Ctrl + P (Print / Print to PDF)
        if (cmdOrCtrl && e.key.toLowerCase() === 'p') {
          e.preventDefault();
        }
        // Block F12 (DevTools)
        if (e.key === 'F12') {
          e.preventDefault();
        }
        // Block Cmd+Option+I / Ctrl+Shift+I (DevTools)
        if (cmdOrCtrl && (e.shiftKey || e.altKey) && e.key.toLowerCase() === 'i') {
          e.preventDefault();
        }
      });
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <AnnouncementBar />
    {!hideNav && <Nav home={home} path={localePath} />}
    <main id="main">
      <slot />
    </main>
    {localePath !== '/connect/' && <ConnectCta />}
    <Footer />
    {site.languages.showSwitcher && <LangSwitcher />}
    <Lightbox />
    <Reveal />
  </body>
</html>
