---
// Manrope variable (subsets unicode-range-gated); Cormorant trimmed to latin
// for English content (§9.5). font-display:swap is the @fontsource default.
import '@fontsource-variable/manrope';
import '@fontsource/cormorant-garamond/latin-400.css';
import '@fontsource/cormorant-garamond/latin-600.css';
import '@fontsource/cormorant-garamond/latin-300-italic.css';
import '@fontsource/cormorant-garamond/latin-400-italic.css';
import '../styles/global.css';

import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import defaultOg from '../assets/hero/desktop/01-diwali-lanterns-jaipur.jpg';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import Lightbox from '../components/Lightbox.astro';
import ConnectCta from '../components/ConnectCta.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import { getSiteSettings } from '../lib/site';

interface Props {
  title: string;
  description: string;
  ogImage?: ImageMetadata;
  ogType?: string;
  /** Home page only: nav starts transparent over the hero, then turns solid on scroll. */
  home?: boolean;
}

const { title, description, ogImage, ogType = 'website', home = false } = Astro.props;

// Global Site Settings (CMS): SEO defaults, share image, analytics, announcement.
const site = await getSiteSettings();
const metaDescription = description?.trim() ? description : site.seo.defaultDescription;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const og = await getImage({
  src: ogImage ?? site.seo.shareImage ?? defaultOg,
  width: 1200,
  height: 630,
  format: 'jpg',
  fit: 'cover',
});
const ogUrl = new URL(og.src, Astro.site).toString();

// Announcement bar offsets the (locked) nav via a CSS class — no nav markup change.
const showAnnounce = site.announcement.enabled && site.announcement.text.trim() !== '';
---

<!doctype html>
<html lang="en" class={showAnnounce ? 'has-announce' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0806" />
    <meta name="generator" content={Astro.generator} />

    <!-- OpenGraph / Twitter -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.seo.ogSiteName} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogUrl} />

    {
      /* Privacy-friendly analytics — external (never inline, CSP-safe), rendered
         only when the client sets a script URL. Enabling it also requires
         whitelisting the origin in public/_headers. */
    }
    {
      site.analytics.scriptUrl && (
        <script
          defer
          src={site.analytics.scriptUrl}
          data-site={site.analytics.siteId || undefined}
        />
      )
    }

    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <CustomCursor />
    <AnnouncementBar />
    <Nav home={home} path={Astro.url.pathname} />
    <main id="main">
      <slot />
    </main>
    {Astro.url.pathname !== '/connect/' && <ConnectCta />}
    <Footer />
    <Lightbox />
  </body>
</html>
