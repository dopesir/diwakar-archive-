---
// Site-wide pre-footer: the Connect & Collaborate call-to-action shown as the
// last section of every page (Base.astro skips it on /connect/, which carries
// the full-page version of the same content).
import SocialLinks from './SocialLinks.astro';
import { getSiteSettings } from '../lib/site';

const { contact, connect } = await getSiteSettings();
---

<section class="connect-cta" aria-label="Connect and collaborate">
  <p class="sec-eyebrow">{connect.eyebrow}</p>
  <h2>{connect.heading}</h2>
  <p class="connect-cta-body">{connect.body}</p>
  <SocialLinks />
  {
    (contact.email || contact.phone) && (
      <p class="connect-contact">
        {contact.email && <a href={`mailto:${contact.email}`}>{contact.email}</a>}
        {contact.email && contact.phone && <span class="sep"> · </span>}
        {contact.phone && <a href={`tel:${contact.phone.replace(/\s+/g, '')}`}>{contact.phone}</a>}
      </p>
    )
  }
  <p class="soc-note">{connect.note}</p>
</section>

<style>
  .connect-cta {
    max-width: 700px;
    margin: 0 auto;
    padding: 4.5rem 2rem 4rem;
    text-align: center;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }
  .connect-cta h2 {
    font-size: clamp(1.6rem, 3.6vw, 2.4rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0.9rem 0 1.2rem;
  }
  .connect-cta-body {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--smoke);
    margin-bottom: 1.8rem;
  }
  @media (max-width: 480px) {
    .connect-cta {
      padding: 3rem 1.2rem 2.5rem;
    }
  }
</style>
