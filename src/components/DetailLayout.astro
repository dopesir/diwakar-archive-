---
import { Picture, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import GrainOverlay from './GrainOverlay.astro';
import { paletteFor } from '../lib/palettes';

interface NavLink {
  href: string;
  title: string;
}
interface Props {
  kind: string; // "Work" | "Stories" | "Thoughts"
  baseHref: string; // "/work/"
  title: string;
  metaItems: (string | undefined)[];
  image?: ImageMetadata;
  imageAlt?: string;
  /** Hero photo opens the lightbox (work items with a photo). */
  lightbox?: boolean;
  quote?: string;
  placeholderIndex?: number;
  prev?: NavLink | null;
  next?: NavLink | null;
  transitionName?: string;
}
const {
  kind,
  baseHref,
  title,
  metaItems,
  image,
  imageAlt,
  lightbox = false,
  quote,
  placeholderIndex = 0,
  prev,
  next,
  transitionName,
} = Astro.props;

const meta = metaItems.filter(Boolean) as string[];
const [pa, pb] = paletteFor(placeholderIndex);
const big = image && lightbox ? await getImage({ src: image, width: 1600, format: 'webp', quality: 78 }) : null;
---

<article class="detail">
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href={baseHref}>{kind}</a> <span>/</span>
    {title}
  </nav>

  {
    image ? (
      lightbox ? (
        <button
          type="button"
          class="detail-hero detail-hero-btn"
          data-lb={big!.src}
          data-lbcap={imageAlt ?? title}
          aria-label="View larger photo"
        >
          <Picture
            src={image}
            alt={imageAlt ?? title}
            widths={[700, 1100, 1600]}
            sizes="(max-width: 1100px) 100vw, 1100px"
            formats={['avif', 'webp']}
            fallbackFormat="jpg"
            quality={74}
            loading="eager"
            fetchpriority="high"
          />
          <GrainOverlay opacity={0.45} baseFrequency={0.9} />
        </button>
      ) : (
        <figure class="detail-hero">
          <Picture
            src={image}
            alt={imageAlt ?? title}
            widths={[700, 1100, 1600]}
            sizes="(max-width: 1100px) 100vw, 1100px"
            formats={['avif', 'webp']}
            fallbackFormat="jpg"
            quality={74}
            loading="eager"
            fetchpriority="high"
            
          />
          <GrainOverlay opacity={0.45} baseFrequency={0.9} />
        </figure>
      )
    ) : (
      <div class="detail-hero is-placeholder ph" style={`--ph-a:${pa};--ph-b:${pb}`}>
        <GrainOverlay opacity={0.5} baseFrequency={0.85} />
      </div>
    )
  }

  {
    meta.length > 0 && (
      <div class="detail-meta">
        {meta.map((m, idx) => (
          <>
            {idx > 0 && <span class="sep">·</span>}
            <span>{m}</span>
          </>
        ))}
      </div>
    )
  }

  <h1 class="detail-title">{title}</h1>

  <div class="detail-body">
    <slot />
  </div>

  {quote && <blockquote class="detail-quote">{quote}</blockquote>}

  {
    (prev || next) && (
      <nav class="prevnext" aria-label={`${kind} navigation`}>
        {prev ? (
          <a class="pn-prev" href={prev.href}>
            <span class="pn-dir">← Previous</span>
            <span class="pn-ttl">{prev.title}</span>
          </a>
        ) : (
          <span />
        )}
        {next && (
          <a class="pn-next" href={next.href}>
            <span class="pn-dir">Next →</span>
            <span class="pn-ttl">{next.title}</span>
          </a>
        )}
      </nav>
    )
  }
</article>

<style>
  .detail-hero-btn {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: #1a1208;
    cursor: pointer;
  }
</style>
