---
// quote block (3A). Reuses the existing pull-quote treatment (.detail-quote).
const { block } = Astro.props;
---

{
  block?.text && (
    <blockquote class="block block-quote detail-quote">
      <span>{block.text}</span>
      {block.cite && <cite class="block-quote-cite">— {block.cite}</cite>}
    </blockquote>
  )
}
