---
// gallery block (3A). A constrained-column grid of images, each opening in the
// site-wide lightbox. Columns come from a select (2|3|4); collapses on mobile.
import { Image, getImage } from 'astro:assets';
const { block } = Astro.props;
const cols = ['2', '3', '4'].includes(block?.columns) ? block.columns : '3';
const items = Array.isArray(block?.images) ? block.images : [];
const prepared = await Promise.all(
  items.map(async (it: any) => ({
    src: it.image,
    big: (await getImage({ src: it.image, width: 1600, format: 'webp', quality: 80 })).src,
    alt: it.alt ?? it.caption ?? '',
    cap: it.caption ?? '',
  })),
);
---

{
  prepared.length > 0 && (
    <div class="block block-gallery" data-cols={cols}>
      {prepared.map((it) => (
        <figure class="block-gallery-item">
          <button
            type="button"
            class="block-gallery-btn"
            data-lb={it.big}
            data-lbcap={it.cap || it.alt}
            aria-label="View larger photo"
          >
            <Image
              src={it.src}
              alt={it.alt}
              widths={[400, 800]}
              sizes="(max-width: 760px) 50vw, 360px"
              loading="lazy"
              decoding="async"
            />
          </button>
          {it.cap && <figcaption>{it.cap}</figcaption>}
        </figure>
      ))}
    </div>
  )
}
