---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { objectPosition } from '../lib/media';

interface Props {
  entry: CollectionEntry<'work'>;
  index: number;
}
const { entry, index } = Astro.props;
const { title, year, image, alt, caption, focalPoint } = entry.data;

const pos = objectPosition(focalPoint);
---

<a class="minimal-item fu" href={`/work/${entry.id}/`}>
  <div class="minimal-image-wrapper">
    {
      image && (
        <Picture
          src={image}
          alt={alt ?? caption ?? title}
          style={pos ? `object-position:${pos}` : undefined}
          widths={[800, 1200, 2000]}
          sizes="(max-width: 900px) 100vw, 70vw"
          formats={['avif', 'webp']}
          fallbackFormat="jpg"
          quality={80}
          loading={index < 4 ? 'eager' : 'lazy'}
          fetchpriority={index < 2 ? 'high' : 'auto'}
          decoding="async"
        />
      )
    }
  </div>
  <div class="minimal-text">
    <span class="minimal-title">{title}</span>
    <span class="minimal-meta">{year}</span>
  </div>
</a>
