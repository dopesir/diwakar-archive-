---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import GrainOverlay from './GrainOverlay.astro';
import { paletteFor } from '../lib/palettes';
import { objectPosition } from '../lib/media';

interface Props {
  entry: CollectionEntry<'work'>;
  index: number;
  /** Bento size (3D) — only set when the listing sort is manual. */
  size?: string;
}
const { entry, index, size } = Astro.props;
const { title, year, image, alt, caption, focalPoint } = entry.data;

const [pa, pb] = paletteFor(index);
const pos = objectPosition(focalPoint);
---

<a
  class="work-card fu"
  href={`/work/${entry.id}/`}
  style={`transition-delay:${(index % 6) * 0.07}s`}
  data-size={size}
>
  <div class="wimg">
    {
      image ? (
        <Picture
          src={image}
          alt={alt ?? caption ?? title}
          class="wimg-bg"
          style={pos ? `object-position:${pos}` : undefined}
          widths={[400, 800, 1200]}
          sizes="(max-width: 600px) 92vw, (max-width: 1100px) 45vw, 350px"
          formats={['avif', 'webp']}
          fallbackFormat="jpg"
          quality={72}
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="wimg-bg wimg-ph ph" style={`--ph-a:${pa};--ph-b:${pb}`}>
          <GrainOverlay opacity={0.4} />
        </div>
      )
    }
    <div class="wimg-veil"></div>
    <div class="wimg-grain"></div>
    <span class="wimg-lbl">{image ? 'View Frame' : 'Archival'}</span>
  </div>
  <div class="wcap">{title}</div>
  <div class="wyr">{year}</div>
</a>
