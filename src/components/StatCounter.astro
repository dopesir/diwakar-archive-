---
// Stats block. Numeric stats animate once when scrolled into view; under
// reduced motion (or no JS) the final values render immediately. The figures
// and labels are CMS-editable (sections.yaml → stats.items); a `value` that
// parses to a number animates, anything else (e.g. "∞") renders verbatim.
import type { StatItem } from '../lib/site';

interface Props {
  items: StatItem[];
}
const { items } = Astro.props;
const fmt = (n: number) => n.toLocaleString('en-US');

const rows = items.map((s) => {
  const n = parseInt(s.value.replace(/,/g, ''), 10);
  const isNumeric = !Number.isNaN(n) && String(n) === s.value.replace(/[,\s]/g, '');
  const suffix = s.suffix ?? '';
  return {
    label: s.label,
    suffix,
    count: isNumeric ? n : undefined,
    display: isNumeric ? `${fmt(n)}${suffix}` : s.value,
  };
});
---

<div class="stats" id="statsBlock">
  {
    rows.map((s) => (
      <div class="stat">
        <div class="stat-n" data-count={s.count ?? undefined} data-suffix={s.suffix || undefined}>
          {s.display}
        </div>
        <div class="stat-l">{s.label}</div>
      </div>
    ))
  }
</div>

<script>
  const block = document.getElementById('statsBlock');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (block && !reduce) {
    const nums = block.querySelectorAll<HTMLElement>('.stat-n[data-count]');

    const animate = (el: HTMLElement) => {
      const target = parseInt(el.dataset.count || '0', 10);
      const suffix = el.dataset.suffix || '';
      if (isNaN(target)) return;
      const dur = 1600;
      const start = performance.now();
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        const eased = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
        const val = Math.round(eased * target);
        el.textContent = (val >= 1000 ? val.toLocaleString('en-US') : String(val)) + suffix;
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const obs = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            nums.forEach(animate);
            obs.disconnect();
            break;
          }
        }
      },
      { threshold: 0.3 },
    );
    obs.observe(block);
  }
</script>
