---
import { Picture } from 'astro:assets';
import heroImg from '../assets/hero-section.jpg';

const caption = "RAJASTHAN, 2011"; // Editable caption
---

<header class="static-hero">
  <div class="sh-bg">
    <Picture
      src={heroImg}
      alt="Purushottam Diwakar - Hero"
      widths={[600, 1000, 1400, 2000]}
      sizes="100vw"
      formats={['avif', 'webp']}
      fallbackFormat="jpg"
      loading="eager"
      decoding="sync"
      class="sh-img"
    />
    <div class="sh-scrim"></div>
  </div>

  <div class="sh-content">
    <div class="sh-top">
      <h1 class="sh-title">PURUSHOTTAM DIWAKAR</h1>
      <nav class="sh-nav">
        <a href="/work/">Work</a>
        <a href="/stories/">Stories</a>
        <a href="/about/">About</a>
        <a href="/connect/">Connect</a>
      </nav>
    </div>

    <div class="sh-bottom">
      <div class="sh-scroll">
        <span>SCROLL</span>
        <div class="sh-scroll-line"></div>
      </div>
      <div class="sh-caption">
        {caption}
      </div>
    </div>
  </div>
</header>
