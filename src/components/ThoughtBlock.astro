---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'thoughts'>;
  index: number;
}
const { entry } = Astro.props;
const { title, date } = entry.data;

const raw = (entry.body ?? '')
  .replace(/<!--[\s\S]*?-->/g, '')
  .replace(/\s+/g, ' ')
  .trim();
const excerpt = raw.length > 200 ? raw.slice(0, 200).replace(/\s+\S*$/, '') + '…' : raw;
---

<a class="exhibition-item" href={`/thoughts/${entry.id}/`} data-reveal style="justify-content: center; text-align: center;">
  <div style="max-width: 800px; padding: 10vh 0;">
    <span class="exhibition-meta" style="margin-bottom: 2rem;">{date}</span>
    <span class="exhibition-title" style="font-size: clamp(2rem, 4vw, 5rem);">{title}</span>
    <p style="margin-top: 2rem; opacity: 0.8; font-weight: 300;">{excerpt}</p>
  </div>
</a>
