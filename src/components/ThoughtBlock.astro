---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'thoughts'>;
  index: number;
}
const { entry, index } = Astro.props;
const { title, date, quote } = entry.data;

const raw = (entry.body ?? '')
  .replace(/<!--[\s\S]*?-->/g, '')
  .replace(/\s+/g, ' ')
  .trim();
const excerpt = raw.length > 200 ? raw.slice(0, 200).replace(/\s+\S*$/, '') + '…' : raw;
const delay = (index % 5) * 0.07;
---

<a class="thought-block fu" href={`/thoughts/${entry.id}/`} style={`transition-delay:${delay}s`}>
  <div class="t-loc">{date}</div>
  <h2 class="t-title">{title}</h2>
  <p class="t-body">{excerpt}</p>
  {quote && <div class="s-quote">{quote}</div>}
  <span class="s-more">Read the reflection →</span>
</a>
