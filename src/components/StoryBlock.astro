---
import { Picture } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { objectPosition } from '../lib/media';

interface Props {
  entry: CollectionEntry<'stories'>;
  index: number;
}
const { entry, index } = Astro.props;
const { title, date, image, alt, focalPoint } = entry.data;

const pos = objectPosition(focalPoint);
const year = date ? new Date(date).getFullYear() : '';
---

<a class="story-item fu" href={`/stories/${entry.id}/`}>
  <div class="story-image-wrapper">
    {
      image && (
        <Picture
          src={image}
          alt={alt ?? title}
          style={pos ? `object-position:${pos}` : undefined}
          widths={[800, 1200, 2000]}
          sizes="(max-width: 900px) 100vw, 90vw"
          formats={['avif', 'webp']}
          fallbackFormat="jpg"
          quality={75}
          loading={index < 4 ? 'eager' : 'lazy'}
          fetchpriority={index < 2 ? 'high' : 'auto'}
          decoding="async"
        />
      )
    }
  </div>
  <div class="story-text">
    <h2 class="story-title">{title}</h2>
    <span class="story-meta">{year}</span>
  </div>
</a>
