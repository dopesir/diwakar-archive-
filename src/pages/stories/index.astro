---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StoryBlock from '../../components/StoryBlock.astro';
import { isPublished } from '../../lib/content';
import { getLayoutSettings, sortEntries } from '../../lib/layout';

const L = await getLayoutSettings();
const grid = L.grids.stories;
const stories = sortEntries(
  await getCollection('stories', ({ data }) => isPublished(data)),
  grid.sort,
);
const description = 'Chronicles from the field — visual narratives.';
---

<Base title="Stories — Purushottam Diwakar Archive" description={description}>
  <section class="sec" style="padding-top: 15vh;">
    <div style="text-align: center; margin-bottom: 5vh;">
      <h1 style="font-family: var(--font-ui); font-size: 0.8rem; font-weight: 300; letter-spacing: 0.3em; text-transform: uppercase;">Chronicles</h1>
    </div>
    <div class="story-list">
      {
        stories.map((entry, i) => (
          <StoryBlock entry={entry} index={i} />
        ))
      }
    </div>
  </section>
</Base>
