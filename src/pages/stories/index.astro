---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StoryBlock from '../../components/StoryBlock.astro';
import Reveal from '../../components/Reveal.astro';
import { isPublished } from '../../lib/content';
import { getLayoutSettings, sectionAttrs, listAttrs, sortEntries, itemSize } from '../../lib/layout';

// Layout controls (3D). Default = single-column block flow, year-desc order.
const L = await getLayoutSettings();
const grid = L.grids.stories;
const stories = sortEntries(
  await getCollection('stories', ({ data }) => isPublished(data)),
  grid.sort,
);
const description =
  'Chronicles from the field — visual narratives from over two decades of assignments by photojournalist Purushottam Diwakar.';
---

<Base title="Stories — Purushottam Diwakar Archive" description={description}>
  <section class="sec">
    <div class="sec-head" {...sectionAttrs(L.sections.storiesIntro)}>
      <p class="sec-eyebrow">Visual Narratives</p>
      <h1 class="sec-title fu">Chronicles from the field</h1>
    </div>
    <div {...listAttrs(grid)}>
      {
        stories.map((entry, i) => (
          <StoryBlock entry={entry} index={i} size={itemSize(entry.data.size, grid.sort)} />
        ))
      }
    </div>
  </section>
  <Reveal />
</Base>
