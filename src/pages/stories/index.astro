---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StoryBlock from '../../components/StoryBlock.astro';
import Reveal from '../../components/Reveal.astro';

const stories = (await getCollection('stories', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.year - a.data.year,
);
const description =
  'Chronicles from the field — visual narratives from over two decades of assignments by photojournalist Purushottam Diwakar.';
---

<Base title="Stories — Purushottam Diwakar Archive" description={description}>
  <section class="sec">
    <p class="sec-eyebrow">Visual Narratives</p>
    <h1 class="sec-title fu">Chronicles from the field</h1>
    <div>
      {stories.map((entry, i) => <StoryBlock entry={entry} index={i} />)}
    </div>
  </section>
  <Reveal />
</Base>
