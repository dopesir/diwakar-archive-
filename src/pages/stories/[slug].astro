---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import DetailLayout from '../../components/DetailLayout.astro';

export async function getStaticPaths() {
  const stories = (await getCollection('stories', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.year - a.data.year,
  );
  return stories.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, index: i, prev: stories[i - 1] ?? null, next: stories[i + 1] ?? null },
  }));
}

const { entry, index, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, year, location, quote } = entry.data;

const raw = (entry.body ?? '').replace(/\s+/g, ' ').trim();
const description = raw.length > 155 ? raw.slice(0, 155).replace(/\s+\S*$/, '') + '…' : raw;
const prevLink = prev ? { href: `/stories/${prev.id}/`, title: prev.data.title } : null;
const nextLink = next ? { href: `/stories/${next.id}/`, title: next.data.title } : null;
---

<Base title={`${title} — Stories — P. Diwakar Archive`} description={description} ogType="article">
  <DetailLayout
    kind="Stories"
    baseHref="/stories/"
    title={title}
    metaItems={[location, String(year)]}
    quote={quote}
    placeholderIndex={index}
    prev={prevLink}
    next={nextLink}
  >
    <Content />
  </DetailLayout>
</Base>
