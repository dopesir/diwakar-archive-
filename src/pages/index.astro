---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Base from "../layouts/Base.astro";
import WorkCard from "../components/WorkCard.astro";
import { getSectionSettings } from "../lib/site";

const sections = await getSectionSettings();
const { intro, stats, featured } = sections;

const allWork = await getCollection("work");
const featuredWork = allWork
  .sort((a, b) => (b.data.year || 0) - (a.data.year || 0))
  .slice(0, 4);

const heroSlides = await getCollection("hero");

const description = "Purushottam Diwakar — War Photography & Rural Movements";
---

<Base title="Purushottam Diwakar — Legacy Archive" description={description} home={true} hideNav={false}>
  <div class="exhibition-container">
    <header class="museum-hero" id="museum-hero">
      <div class="mh-bg">
        {heroSlides.map((slide, index) => (
          <Picture
            src={slide.data.imageDesktop}
            alt={slide.data.alt || "Purushottam Diwakar Archive"}
            widths={[800, 1600, 2400]}
            sizes="100vw"
            formats={["avif", "webp"]}
            fallbackFormat="jpg"
            quality={100}
            loading={index === 0 ? "eager" : "lazy"}
            decoding={index === 0 ? "sync" : "async"}
            class={`mh-img ${index === 0 ? 'active' : ''}`}
            style={index === 0 ? "view-transition-name: hero-img;" : ""}
          />
        ))}
        <div class="mh-overlay"></div>
      </div>
      
      <div class="mh-ui">
        <div class="mh-bottom-center">
          <div class="mh-scroll-line"></div>
          <div class="mh-scroll-text">SCROLL</div>
        </div>
        
        <div class="mh-mid-left">
          <div class="mh-caption-line"></div>
          <div class="mh-caption" id="mh-caption">INDIA, 1987—</div>
        </div>
      </div>
    </header>

    <section class="narrative-bio">
      <div class="bio-content">
        <div class="bio-eyebrow">{intro.eyebrow}</div>
        
        {intro.paragraphs.map((p) => (
          <p class="bio-paragraph">{p}</p>
        ))}
        
        <div class="bio-signature">{intro.signature}</div>
      </div>
    </section>

    {stats.visible && (
      <section class="home-stats">
        <div class="stats-grid">
          {stats.items.map((s, i) => (
            <div class="stat-item fu" style={`transition-delay: ${i * 0.15}s`}>
              <div class="stat-value">{s.value}<span class="stat-suffix">{s.suffix}</span></div>
              <div class="stat-label">{s.label}</div>
            </div>
          ))}
        </div>
      </section>
    )}

    {featured.visible && featuredWork.length > 0 && (
      <section class="home-featured">
        <div class="hf-header fu">
          <h2 class="hf-title">{featured.heading}</h2>
          <a href="/work/" class="hf-link">View Archive</a>
        </div>
        <div class="minimal-grid">
          {featuredWork.map((entry, index) => (
            <WorkCard entry={entry} index={index} />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  .exhibition-container {
    background: var(--parch);
    color: var(--ink);
    min-height: 100vh;
  }
  
  /* Museum Hero Section */
  .museum-hero {
    position: relative;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: #000;
  }
  
  .mh-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  
  .mh-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 50%;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    will-change: opacity;
  }
  
  .mh-img.active {
    opacity: 1;
  }
  
  .mh-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.1) 20%, rgba(0,0,0,0) 50%, rgba(0,0,0,0.3) 100%);
    pointer-events: none;
  }
  
  .mh-ui {
    position: absolute;
    inset: 0;
    padding: 3rem;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    font-family: var(--font-ui, sans-serif);
    color: #ffffff;
  }
  
  /* Top alignment spacing for the real Nav */
  /* Bottom Center: Scroll */
  .mh-bottom-center {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .mh-scroll-line {
    width: 1px;
    height: 32px;
    background-color: #ffffff;
    opacity: 0.4;
  }
  .mh-scroll-text {
    font-size: 0.65rem;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* Middle Left: Caption */
  .mh-mid-left {
    position: absolute;
    top: 50%;
    left: 4rem;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    text-align: left;
  }
  .mh-caption-line {
    width: 24px;
    height: 1px;
    background-color: #ffffff;
    opacity: 0.6;
  }
  .mh-caption {
    font-size: 0.7rem;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
  
  /* Narrative Biography */
  .narrative-bio {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    background: #ffffff;
    padding: 12rem 8rem;
  }
  
  .bio-content {
    max-width: 900px;
    margin: 0;
    font-family: var(--font-ui, sans-serif);
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  
  .bio-eyebrow {
    font-size: 0.85rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--smoke);
    margin-bottom: 2rem;
    position: relative;
    padding-left: 3rem;
  }
  
  .bio-eyebrow::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 2rem;
    height: 1px;
    background-color: var(--smoke);
  }
  
  .bio-paragraph {
    font-size: clamp(1.5rem, 4vw, 3rem);
    line-height: 1.4;
    font-weight: 300;
    margin: 0;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  
  .bio-signature {
    margin-top: 4rem;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--smoke);
    text-align: right;
  }
  
  @media (max-width: 1024px) {
    .narrative-bio { padding: 8rem 4rem; }
  }
  @media (max-width: 768px) {
    .mh-mid-left { left: 1.5rem; }
    .mh-bottom-center { bottom: 1.5rem; }
    .narrative-bio { padding: 4rem 2rem; }
  }

  /* Stats Section */
  .home-stats {
    padding: 6rem 8rem;
    background: var(--parch);
    border-top: 1px solid rgba(0,0,0,0.05);
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .stats-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4rem;
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .stat-value {
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .stat-suffix {
    font-size: 0.5em;
    vertical-align: super;
    color: var(--smoke);
  }
  .stat-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--smoke);
  }

  /* Featured Section */
  .home-featured {
    padding: 12rem 0;
    background: var(--parch);
  }
  .hf-header {
    max-width: 1400px;
    margin: 0 auto 8rem;
    padding: 0 4rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .hf-title {
    font-size: 2rem;
    font-weight: 300;
    margin: 0;
    color: var(--ink);
  }
  .hf-link {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--smoke);
    border-bottom: 1px solid transparent;
    transition: all 0.3s;
    padding-bottom: 0.2rem;
  }
  .hf-link:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  @media (max-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); row-gap: 6rem; }
    .home-stats { padding: 6rem 4rem; }
  }
  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: 1fr; row-gap: 4rem; }
    .home-stats { padding: 4rem 2rem; }
    .home-featured { padding: 8rem 0; }
    .hf-header { padding: 0 1.5rem; flex-direction: column; align-items: flex-start; gap: 2rem; margin-bottom: 4rem; }
  }
</style>

<script>
  // Simple background image fader
  document.addEventListener('astro:page-load', () => {
    const hero = document.getElementById('museum-hero');
    if (!hero) return;
    
    const images = hero.querySelectorAll('.mh-img');
    const caption = document.getElementById('mh-caption');
    if (images.length <= 1) return;
    
    // We can pull the locations from the dataset if we want to change the caption,
    // but the user's design had a static "INDIA, 1987—" which works perfectly as an anchor.
    
    let currentIndex = 0;
    let faderInterval;
    
    function nextImage() {
      images[currentIndex].classList.remove('active');
      currentIndex = (currentIndex + 1) % images.length;
      images[currentIndex].classList.add('active');
    }
    
    faderInterval = setInterval(nextImage, 5000);
    
    // Cleanup to prevent duplicate intervals on view transitions
    document.addEventListener('astro:before-swap', () => {
      clearInterval(faderInterval);
    }, { once: true });
  });
</script>
