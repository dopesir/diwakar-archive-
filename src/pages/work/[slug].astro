---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import DetailLayout from '../../components/DetailLayout.astro';
import { isPublished } from '../../lib/content';

export async function getStaticPaths() {
  const work = (await getCollection('work', ({ data }) => isPublished(data))).sort(
    (a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title),
  );
  return work.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, index: i, prev: work[i - 1] ?? null, next: work[i + 1] ?? null },
  }));
}

const { entry, index, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, year, location, image, alt, caption, seo } = entry.data;

const descBase = caption ?? `${title}${location ? ' — ' + location : ''} · ${year}`;
const description = `${descBase}. From the Purushottam Diwakar Legacy Archive.`;
const prevLink = prev ? { href: `/work/${prev.id}/`, title: prev.data.title } : null;
const nextLink = next ? { href: `/work/${next.id}/`, title: next.data.title } : null;
const schema = {
  "@context": "https://schema.org",
  "@type": "VisualArtwork",
  "name": title,
  "artMedium": "Photography",
  "dateCreated": String(year),
  "creator": {
    "@type": "Person",
    "name": "Purushottam Diwakar"
  },
  ...(image && { "image": new URL(image.src, Astro.site || 'https://diwakar-archive.pages.dev').toString() }),
  ...(description && { "description": description }),
  ...(location && { "locationCreated": { "@type": "Place", "name": location } })
};
---

<Base
  title={`${title} — Work — P. Diwakar Archive`}
  description={description}
  ogImage={image}
  ogType="article"
  seoTitle={seo?.seoTitle}
  seoDescription={seo?.seoDescription}
  shareImage={seo?.shareImage}
  noindex={seo?.noindex}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <DetailLayout
    kind="Work"
    baseHref="/work/"
    title={title}
    metaItems={[location, String(year), caption]}
    image={image}
    imageAlt={alt ?? caption ?? title}
    lightbox={!!image}
    placeholderIndex={index}
    prev={prevLink}
    next={nextLink}
    transitionName={`img-${entry.id}`}
  >
    <Content />
  </DetailLayout>
</Base>
