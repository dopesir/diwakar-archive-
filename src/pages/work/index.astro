---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorkCard from '../../components/WorkCard.astro';
import { isPublished } from '../../lib/content';
import { getLayoutSettings, sortEntries } from '../../lib/layout';

const L = await getLayoutSettings();
const grid = L.grids.work;
const work = sortEntries(
  await getCollection('work', ({ data }) => isPublished(data)),
  grid.sort,
  true,
);
const description = 'The archive — selected frames from over 27 years of photojournalism.';
---

<Base title="Work — Purushottam Diwakar Archive" description={description}>
  <section class="sec" style="padding-top: 15vh;">
    <div style="text-align: center; margin-bottom: 5vh;">
      <h1 style="font-family: var(--font-ui); font-size: 0.8rem; font-weight: 300; letter-spacing: 0.3em; text-transform: uppercase;">Selected Frames</h1>
    </div>
    <div class="minimal-grid">
      {
        work.map((entry, i) => (
          <WorkCard entry={entry} index={i} />
        ))
      }
    </div>
  </section>
</Base>
