---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorkCard from '../../components/WorkCard.astro';
import Reveal from '../../components/Reveal.astro';

const work = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title),
);
const description =
  'The archive — selected frames from over 27 years of photojournalism across Rajasthan, India and beyond by Purushottam Diwakar.';
---

<Base title="Work — Purushottam Diwakar Archive" description={description}>
  <section class="sec">
    <p class="sec-eyebrow">The Archive</p>
    <h1 class="sec-title fu">Selected frames — un&#8209;staged, unflinching.</h1>
    <div class="work-grid">
      {work.map((entry, i) => <WorkCard entry={entry} index={i} />)}
    </div>
  </section>
  <Reveal />
</Base>
