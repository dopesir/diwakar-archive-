---
import Base from '../layouts/Base.astro';
import { Picture } from 'astro:assets';

import titles from '../data/india-today-titles.json';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/india-today/*.{jpeg,jpg,png,gif,webp,JPG,JPEG,PNG}', { eager: true });
const imageEntries = Object.entries(images).map(([path, mod]) => {
  const filename = path.split('/').pop() || "";
  let title = (titles as Record<string, string>)[filename];
  
  if (!title) {
    const base = filename.replace(/\.[^/.]+$/, "") || "India Today";
    title = base.replace(/[-_]/g, ' ');
  }
  return { img: mod.default, title };
});

const title = "India Today Archive";
const description = "Selected frames and covers from a long-standing association with India Today.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "name": title,
  "description": description,
  "url": new URL(Astro.url.pathname, Astro.site || 'https://diwakar-archive.pages.dev').toString(),
  "image": imageEntries.map(entry => ({
    "@type": "ImageObject",
    "url": new URL(entry.img.src, Astro.site || 'https://diwakar-archive.pages.dev').toString(),
    "caption": entry.title,
    "creator": {
      "@type": "Person",
      "name": "Purushottam Diwakar"
    }
  }))
};
---

<Base title={`${title} — Purushottam Diwakar Archive`} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <section class="sec" style="padding-top: 15vh;">
    <div style="text-align: center; margin-bottom: 5vh;">
      <h1 style="font-family: var(--font-ui); font-size: 0.8rem; font-weight: 300; letter-spacing: 0.3em; text-transform: uppercase;">
        {title}
      </h1>
      <p style="margin-top: 2rem; font-family: var(--font-body); color: var(--color-ink-light);">
        {description}
      </p>
    </div>
    <div class="minimal-grid">
      {
        imageEntries.map(({ img, title: imgTitle }, index) => (
          <div class="minimal-item fu" style="margin-bottom: 2rem;">
            <button class="minimal-image-wrapper" style="aspect-ratio: auto; height: auto; background: transparent; border: none; padding: 0; width: 100%; cursor: pointer;" data-lb={img.src} data-lbcap={imgTitle} aria-label={`View photo: ${imgTitle}`}>
              <Picture
                src={img}
                alt={imgTitle}
                style="position: relative; height: auto; object-fit: contain;"
                widths={[800, 1200, 2000]}
                sizes="(max-width: 900px) 100vw, 70vw"
                formats={['avif', 'webp']}
                fallbackFormat="jpg"
                quality={80}
                loading={index < 4 ? 'eager' : 'lazy'}
                fetchpriority={index < 2 ? 'high' : 'auto'}
                decoding="async"
              />
            </button>
            <div class="minimal-text" style="text-align: center; margin-top: 0.75rem;">
              <span class="minimal-title" style="font-size: 0.75rem; color: var(--color-ink-light);">{imgTitle}</span>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</Base>
