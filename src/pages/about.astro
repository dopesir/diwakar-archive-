---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Reveal from '../components/Reveal.astro';
import BlockRenderer from '../components/blocks/BlockRenderer.astro';
import { isPublished } from '../lib/content';
import { getAboutBlocks } from '../lib/site';

import portrait from '../assets/about/portrait.png';
// Biography can be composed from CMS blocks (3A). Empty = the coded prose below.
const aboutBlocks = await getAboutBlocks();

const description =
  'Biography — Purushottam Diwakar, photojournalist with the India Today Group since 1998, founder of the Imagine Photojournalist Society and its Camera Commandos initiative.';
---

<Base title="About — Purushottam Diwakar" description={description} ogImage={portrait}>
  <div class="sec">
    <div class="about-wrap fu">
      <div class="about-text" data-reveal>
        <p class="sec-eyebrow">Biography</p>
        <h1>Observer.<br />Humanist.<br />Archivist.</h1>
        {
          aboutBlocks.length > 0 ? (
            <BlockRenderer blocks={aboutBlocks} />
          ) : (
            <>
              <p>
                Purushottam Diwakar has been a quiet witness to the Indian subcontinent for over 27
                years. Associated with the India Today Group since 1998, his images have appeared on
                the magazine’s cover and in international editorial publications worldwide.
              </p>
              <p>
                His assignments span Rajasthan drought, Gujarat earthquake, Jaipur serial bomb
                blast, and the Godhara massacre. International work has taken him to Ghana, Thailand,
                Congo, and Dubai. He collaborates with UNICEF, Care India, VSO, and Cairn Oil &amp;
                Gas on social-impact photography.
              </p>
              <p>
                In 2012 he founded the <strong>Imagine Photojournalist Society</strong> — including
                the “Camera Commandos” initiative empowering female photojournalists in crisis
                journalism. Masterclasses across Jaipur, Delhi, and Ahmedabad. Work exhibited at
                Jawahar Kala Kendra. Recognised by the Governor of Rajasthan.
              </p>
              <p class="about-quote">
                “Photo capturing is a combination of Science, Arts and Commerce.”
              </p>
            </>
          )
        }
      </div>
      <div class="portrait-box" data-reveal>
        <Image
          src={portrait}
          alt="Portrait of Purushottam Diwakar"
          widths={[400, 800, 1200]}
          sizes="(max-width: 760px) 92vw, 600px"
          loading="lazy"
          decoding="async"
        />
        <div class="portrait-light" aria-hidden="true"></div>
      </div>
    </div>

    <!-- End Biography -->
  </div>
  <Reveal />
</Base>
