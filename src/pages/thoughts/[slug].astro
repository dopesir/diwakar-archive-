---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import DetailLayout from '../../components/DetailLayout.astro';

export async function getStaticPaths() {
  const thoughts = (await getCollection('thoughts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.year - a.data.year,
  );
  return thoughts.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, index: i, prev: thoughts[i - 1] ?? null, next: thoughts[i + 1] ?? null },
  }));
}

const { entry, index, prev, next } = Astro.props;
const { Content } = await render(entry);
const { title, year, location, date, quote, image, alt, caption, seo } = entry.data;

const raw = (entry.body ?? '').replace(/\s+/g, ' ').trim();
const description = raw.length > 155 ? raw.slice(0, 155).replace(/\s+\S*$/, '') + '…' : raw;
// "India Today Archives" has no year — don't show a misleading number in meta.
const yearMeta = date === location ? undefined : String(year);
const prevLink = prev ? { href: `/thoughts/${prev.id}/`, title: prev.data.title } : null;
const nextLink = next ? { href: `/thoughts/${next.id}/`, title: next.data.title } : null;
---

<Base
  title={`${title} — Thoughts — P. Diwakar Archive`}
  description={description}
  ogType="article"
  seoTitle={seo?.seoTitle}
  seoDescription={seo?.seoDescription}
  shareImage={seo?.shareImage}
  noindex={seo?.noindex}
>
  <DetailLayout
    kind="Thoughts"
    baseHref="/thoughts/"
    title={title}
    metaItems={[location, yearMeta, caption]}
    image={image}
    imageAlt={alt ?? caption ?? title}
    lightbox={!!image}
    quote={quote}
    placeholderIndex={index}
    prev={prevLink}
    next={nextLink}
  >
    <Content />
  </DetailLayout>
</Base>
