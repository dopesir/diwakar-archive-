---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ThoughtBlock from '../../components/ThoughtBlock.astro';
import Reveal from '../../components/Reveal.astro';
import { isPublished } from '../../lib/content';
import { getLayoutSettings, sectionAttrs, listAttrs, sortEntries, itemSize } from '../../lib/layout';

// Layout controls (3D). Default = single-column block flow, year-desc order.
const L = await getLayoutSettings();
const grid = L.grids.thoughts;
const thoughts = sortEntries(
  await getCollection('thoughts', ({ data }) => isPublished(data)),
  grid.sort,
);
const description =
  'Behind the frame — reflections on ethics, restraint and the choices a photojournalist makes, by Purushottam Diwakar.';
---

<Base title="Thoughts — Purushottam Diwakar Archive" description={description}>
  <div class="thoughts-bg">
    <section class="sec">
      <div class="sec-head" {...sectionAttrs(L.sections.thoughtsIntro)}>
        <p class="sec-eyebrow">Behind the Frame</p>
        <h1 class="sec-title fu">The story behind the story</h1>
      </div>
      <div {...listAttrs(grid)}>
        {
          thoughts.map((entry, i) => (
            <ThoughtBlock entry={entry} index={i} size={itemSize(entry.data.size, grid.sort)} />
          ))
        }
      </div>
    </section>
  </div>
  <Reveal />
</Base>
