---
import Base from '../layouts/Base.astro';
import Reveal from '../components/Reveal.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { getSiteSettings } from '../lib/site';

const { contact } = await getSiteSettings();
const description =
  'Connect & collaborate — exhibitions, editorial licensing, collaborations and limited-edition prints. Over 1,300 images on Getty Images for immediate licensing.';
---

<Base title="Connect — Purushottam Diwakar" description={description}>
  <div class="contact-page">
    <canvas class="contact-sky" id="contact-sky-canvas" aria-hidden="true"></canvas>
    <div class="contact-inner fu">
      <p class="sec-eyebrow">Connect &amp; Collaborate</p>
      <h1>Find the<br />work online.</h1>
      <p class="contact-body">
        For exhibitions, editorial licensing, collaborations, or limited edition prints. Over 1,300
        images available on Getty Images for immediate licensing.
      </p>

      <SocialLinks />

      {
        (contact.email || contact.phone) && (
          <p class="connect-contact">
            {contact.email && <a href={`mailto:${contact.email}`}>{contact.email}</a>}
            {contact.email && contact.phone && <span class="sep"> · </span>}
            {contact.phone && (
              <a href={`tel:${contact.phone.replace(/\s+/g, '')}`}>{contact.phone}</a>
            )}
          </p>
        )
      }

      <p class="soc-note">Representation by invitation only · India Today Group</p>
    </div>
  </div>
  <Reveal />

  <script>
    // Subtle warm-sky gradient wash behind the contact panel (motion only).
    const cv = document.getElementById('contact-sky-canvas') as HTMLCanvasElement | null;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const ctx = cv?.getContext('2d');
    if (cv && ctx && !reduce) {
      let W = innerWidth,
        H = innerHeight;
      cv.width = W;
      cv.height = H;
      let t = 0,
        run = false,
        raf = 0;
      const draw = () => {
        if (!run) return;
        raf = requestAnimationFrame(draw);
        t += 0.003;
        ctx.clearRect(0, 0, W, H);
        const r = Math.round(210 + Math.sin(t * 0.4) * 16);
        const g = Math.round(185 + Math.sin(t * 0.3) * 13);
        const b = Math.round(155 + Math.sin(t * 0.5) * 20);
        const gr = ctx.createLinearGradient(0, 0, 0, H);
        gr.addColorStop(0, `rgba(${r - 40},${g - 50},${b - 30},.1)`);
        gr.addColorStop(0.6, `rgba(${r},${g},${b},.055)`);
        gr.addColorStop(1, 'rgba(255,255,255,0)');
        ctx.fillStyle = gr;
        ctx.fillRect(0, 0, W, H);
      };
      const start = () => {
        if (run) return;
        run = true;
        cv.classList.add('sky-on');
        draw();
      };
      const stop = () => {
        run = false;
        cancelAnimationFrame(raf);
      };
      addEventListener('resize', () => {
        W = innerWidth;
        H = innerHeight;
        cv.width = W;
        cv.height = H;
      });
      document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));
      start();
    }
  </script>
</Base>
